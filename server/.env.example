# ─── CampusFind server config (template) ───────────────────────────────
# Copy this file to `.env`, fill in real values, and run `npm run dev`.
#
# Notes for whoever maintains this:
#  • dotenv keeps the FIRST occurrence of a variable. Don't duplicate keys.
#  • Anything below this comment block IS read by the server.
#  • Never commit the real `.env`. (`server/.env` is already gitignored.)

# ── MongoDB ──
# Local install: `mongodb://127.0.0.1:27017/<db>` works as-is once the
#   MongoDB service is running. Use 127.0.0.1, not `localhost`, on Windows
#   to avoid IPv6 ::1 resolution issues.
# Atlas cloud: paste the URI from Atlas → Connect → Drivers (replace
#   <password> with your DB user password).
MONGO_URI=mongodb://127.0.0.1:27017/campusfind

# ── Auth ──
# Generate a fresh random secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-hex-string
JWT_EXPIRES_IN=7d

# Google OAuth Client ID — REQUIRED.
# Same value as VITE_GOOGLE_CLIENT_ID in client/.env. Get it at:
#   https://console.cloud.google.com/apis/credentials
#   → OAuth client ID → Web application
GOOGLE_CLIENT_ID=PASTE_YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com

# ── Server ──
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── Email (optional) ──
# Leave SendGrid + SMTP blocks empty unless you want match-notification
# emails. The app runs fine without them.

# SENDGRID_API_KEY=
# SENDGRID_FROM=no-reply@campusfind.local
# EMAIL_FROM=no-reply@campusfind.local

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
