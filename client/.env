# ─── CampusFind client config ──────────────────────────────────────────
# Vite picks these up at build time. Restart `npm run dev` after edits.

# Backend URL — point at your running server.
VITE_API_URL=http://localhost:5000

# Google OAuth client ID — REQUIRED for the sign-in button to render.
# Must match GOOGLE_CLIENT_ID in server/.env. Create one at:
#   https://console.cloud.google.com/apis/credentials
# (OAuth 2.0 Client ID → Web application →
#   Authorized JavaScript origins: http://localhost:3000)
VITE_GOOGLE_CLIENT_ID=746247874618-4f3emnrmkkre60ttgn4h53h28nsp05po.apps.googleusercontent.com