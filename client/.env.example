# ─── CampusFind client config (template) ───────────────────────────────
# Copy this file to `.env` and fill in real values. Restart `npm run dev`
# after editing — Vite reads .env at startup, not on hot-reload.
#
# IMPORTANT: only variables prefixed VITE_ are exposed to the browser.
# A var like `GOOGLE_CLIENT_ID=...` (no prefix) will be silently ignored.

# Backend API URL the frontend talks to.
VITE_API_URL=http://localhost:5000

# Google OAuth Client ID — REQUIRED.
# Where to get it:
#   https://console.cloud.google.com/apis/credentials
#   → Create Credentials → OAuth client ID → Web application
#   → Authorized JavaScript origins must include http://localhost:3000
# Same value must also be set as GOOGLE_CLIENT_ID in server/.env.
VITE_GOOGLE_CLIENT_ID=PASTE_YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
